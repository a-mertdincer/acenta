// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  phone        String?
  country      String?
  passwordHash String
  role         String        @default("CUSTOMER") // ADMIN or CUSTOMER
  reservations Reservation[]
  coupons      Coupon[]
  reviews      Review[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Tour {
  id                 String          @id @default(uuid())
  titleTr            String
  titleEn            String
  titleZh            String
  descTr             String
  descEn             String
  descZh             String
  highlightsEn       String?
  highlightsTr       String?
  highlightsZh       String?
  itineraryEn        String?
  itineraryTr        String?
  itineraryZh        String?
  knowBeforeEn       String?
  knowBeforeTr       String?
  knowBeforeZh       String?
  notSuitableEn      String?
  notSuitableTr      String?
  notSuitableZh      String?
  notAllowedEn       String?
  notAllowedTr       String?
  notAllowedZh       String?
  whatsIncludedEn    String?
  whatsIncludedTr    String?
  whatsIncludedZh    String?
  notIncludedEn      String?
  notIncludedTr      String?
  notIncludedZh      String?
  faqsEn             Json?
  faqsTr             Json?
  faqsZh             Json?
  basePrice          Float // Default price if not overridden by date
  type               String // BALLOON, TOUR, TRANSFER, CONCIERGE, PACKAGE
  destination        String          @default("cappadocia") // slug: cappadocia, antalya, istanbul
  category           String?         // slug: hot-air-balloon, daily-tours, transfers, etc.
  capacity           Int             @default(0) // Default capacity
  transferTiers      Json?           // Legacy: ASR tiers. Prefer transferAirportTiers.
  transferAirportTiers Json?         // For type=TRANSFER: { ASR: [{ minPax, maxPax, price }], NAV: [...] }
  hasTourType        Boolean         @default(false) // Eco/Plus toggle for daily tours
  hasAirportSelect   Boolean         @default(false) // Airport (NAV/ASR) for transfer
  hasReservationType Boolean         @default(true) // Private/Regular toggle
  reservationTypeMode String         @default("private_regular") // private_regular | option2 | option3 | option4 | none
  minAgeLimit        Int?
  ageRestrictionEn   String?
  ageRestrictionTr   String?
  ageRestrictionZh   String?
  slug               String?         @unique // Optional URL slug e.g. green-tour
  isAskForPrice      Boolean         @default(false)
  isFeatured         Boolean         @default(false)
  salesTags          Json?           // string[] e.g. ["best-seller","instant-confirmation"]
  startTimes         Json?           // string[] e.g. ["05:30","09:00","14:00"]
  cancellationNoteEn String?
  cancellationNoteTr String?
  cancellationNoteZh String?

  // Extended locales (nullable; EN/TR/ZH remain canonical until translated)
  titleEs              String?
  titleIt              String?
  titleFr              String?
  titleDe              String?
  titleNl              String?
  titleRo              String?
  titleRu              String?
  titlePl              String?
  titleKo              String?
  titleJa              String?
  descEs               String?
  descIt               String?
  descFr               String?
  descDe               String?
  descNl               String?
  descRo               String?
  descRu               String?
  descPl               String?
  descKo               String?
  descJa               String?
  highlightsEs         String?
  highlightsIt         String?
  highlightsFr         String?
  highlightsDe         String?
  highlightsNl         String?
  highlightsRo         String?
  highlightsRu         String?
  highlightsPl         String?
  highlightsKo         String?
  highlightsJa         String?
  itineraryEs          String?
  itineraryIt          String?
  itineraryFr          String?
  itineraryDe          String?
  itineraryNl          String?
  itineraryRo          String?
  itineraryRu          String?
  itineraryPl          String?
  itineraryKo          String?
  itineraryJa          String?
  knowBeforeEs         String?
  knowBeforeIt         String?
  knowBeforeFr         String?
  knowBeforeDe         String?
  knowBeforeNl         String?
  knowBeforeRo         String?
  knowBeforeRu         String?
  knowBeforePl         String?
  knowBeforeKo         String?
  knowBeforeJa         String?
  notSuitableEs        String?
  notSuitableIt        String?
  notSuitableFr        String?
  notSuitableDe        String?
  notSuitableNl        String?
  notSuitableRo        String?
  notSuitableRu        String?
  notSuitablePl        String?
  notSuitableKo        String?
  notSuitableJa        String?
  notAllowedEs         String?
  notAllowedIt         String?
  notAllowedFr         String?
  notAllowedDe         String?
  notAllowedNl         String?
  notAllowedRo         String?
  notAllowedRu         String?
  notAllowedPl         String?
  notAllowedKo         String?
  notAllowedJa         String?
  whatsIncludedEs      String?
  whatsIncludedIt      String?
  whatsIncludedFr      String?
  whatsIncludedDe      String?
  whatsIncludedNl      String?
  whatsIncludedRo      String?
  whatsIncludedRu      String?
  whatsIncludedPl      String?
  whatsIncludedKo      String?
  whatsIncludedJa      String?
  notIncludedEs        String?
  notIncludedIt        String?
  notIncludedFr        String?
  notIncludedDe        String?
  notIncludedNl        String?
  notIncludedRo        String?
  notIncludedRu        String?
  notIncludedPl        String?
  notIncludedKo        String?
  notIncludedJa        String?
  cancellationNoteEs   String?
  cancellationNoteIt   String?
  cancellationNoteFr   String?
  cancellationNoteDe   String?
  cancellationNoteNl   String?
  cancellationNoteRo   String?
  cancellationNoteRu   String?
  cancellationNotePl   String?
  cancellationNoteKo   String?
  cancellationNoteJa   String?
  ageRestrictionEs     String?
  ageRestrictionIt     String?
  ageRestrictionFr     String?
  ageRestrictionDe     String?
  ageRestrictionNl     String?
  ageRestrictionRo     String?
  ageRestrictionRu     String?
  ageRestrictionPl     String?
  ageRestrictionKo     String?
  ageRestrictionJa     String?
  faqsEs               Json?
  faqsIt               Json?
  faqsFr               Json?
  faqsDe               Json?
  faqsNl               Json?
  faqsRo               Json?
  faqsRu               Json?
  faqsPl               Json?
  faqsKo               Json?
  faqsJa               Json?

  ageGroups          ProductAgeGroup[]
  images             TourImage[]
  priceInquiries     PriceInquiry[]
  attractions        TourAttraction[]
  options            TourOption[]
  prices             TourDatePrice[]
  variants           TourVariant[]
  reservations      Reservation[]
  reviews           Review[]
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
}

model PriceInquiry {
  id            String   @id @default(uuid())
  tourId        String
  tour          Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  name          String
  email         String
  phone         String
  country       String?
  preferredDate String?
  people        Int
  hotelOrCruise String?
  message       String?
  createdAt     DateTime @default(now())

  @@index([tourId])
}

model Attraction {
  id            String             @id @default(uuid())
  slug          String             @unique
  nameEn        String
  nameTr        String
  nameZh        String?
  descriptionEn String?
  descriptionTr String?
  descriptionZh String?
  nameEs        String?
  nameIt        String?
  nameFr        String?
  nameDe        String?
  nameNl        String?
  nameRo        String?
  nameRu        String?
  namePl        String?
  nameKo        String?
  nameJa        String?
  descriptionEs String?
  descriptionIt String?
  descriptionFr String?
  descriptionDe String?
  descriptionNl String?
  descriptionRo String?
  descriptionRu String?
  descriptionPl String?
  descriptionKo String?
  descriptionJa String?
  imageUrl      String?
  sortOrder     Int                @default(0)
  tours         TourAttraction[]
  images        AttractionImage[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
}

model AttractionImage {
  id           String     @id @default(uuid())
  attractionId String
  attraction   Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  url          String
  altEn        String?
  altTr        String?
  altZh        String?
  altEs        String?
  altIt        String?
  altFr        String?
  altDe        String?
  altNl        String?
  altRo        String?
  altRu        String?
  altPl        String?
  altKo        String?
  altJa        String?
  isPrimary    Boolean    @default(false)
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@index([attractionId])
}

model TourAttraction {
  id           String     @id @default(uuid())
  tourId       String
  attractionId String
  tour         Tour       @relation(fields: [tourId], references: [id], onDelete: Cascade)
  attraction   Attraction @relation(fields: [attractionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  @@unique([tourId, attractionId])
}

model TourVariant {
  id                 String   @id @default(uuid())
  tourId             String
  tour               Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  tourType           String?  // "eco" | "plus" | null
  reservationType    String?  // "regular" | "private" | null
  airport            String?  // "NAV" | "ASR" | null
  titleEn            String
  titleTr            String
  titleZh            String
  descEn             String
  descTr             String
  descZh             String
  titleEs            String?
  titleIt            String?
  titleFr            String?
  titleDe            String?
  titleNl            String?
  titleRo            String?
  titleRu            String?
  titlePl            String?
  titleKo            String?
  titleJa            String?
  descEs             String?
  descIt             String?
  descFr             String?
  descDe             String?
  descNl             String?
  descRo             String?
  descRu             String?
  descPl             String?
  descKo             String?
  descJa             String?
  includes           Json     // string[] e.g. ["Klimalı araç", "Rehber"]
  excludes           Json     // string[]
  duration           String?  // "4 saat" or "~40 dakika"
  languages          Json?    // string[] e.g. ["en", "zh", "es"]
  vehicleType        String?
  maxGroupSize       Int?
  routeStops         Json?    // string[]
  adultPrice         Float
  childPrice         Float?   // 4-7 yaş; null = same as adult
  pricingType        String   // "per_person" | "per_vehicle"
  privatePriceTiers  Json?    // [{ minPax, maxPax, price }] for reservationType=private
  sortOrder          Int      @default(0)
  isActive           Boolean  @default(true)
  isRecommended     Boolean  @default(false)
  reservations      Reservation[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Flight {
  id             String   @id @default(uuid())
  code           String   // "TK 2000"
  airline        String
  airport        String   // "NAV" | "ASR"
  direction      String   // "arrival" | "departure"
  estimatedTime  String   // "08:45"
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model TourOption {
  id        String   @id @default(uuid())
  tourId    String
  tour      Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  titleTr   String
  titleEn   String
  titleZh   String
  titleEs   String?
  titleIt   String?
  titleFr   String?
  titleDe   String?
  titleNl   String?
  titleRo   String?
  titleRu   String?
  titlePl   String?
  titleKo   String?
  titleJa   String?
  priceAdd  Float // Amount added to base price
  pricingMode String @default("per_person") // per_person | flat
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TourDatePrice {
  id               String   @id @default(uuid())
  tourId           String
  tour             Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  date             DateTime // Map to specific day
  price            Float // Override base price
  capacityOverride Int? // Override default capacity for this day
  isClosed         Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([tourId, date])
}

model Reservation {
  id               String        @id @default(uuid())
  userId           String?
  guestName        String
  guestEmail       String
  guestPhone       String
  user             User?         @relation(fields: [userId], references: [id], onDelete: SetNull)
  tourId           String
  tour             Tour          @relation(fields: [tourId], references: [id])
  variantId        String?        // When booking with variant system
  variant          TourVariant?   @relation(fields: [variantId], references: [id], onDelete: SetNull)
  date             DateTime
  pax              Int            @default(1)
  totalPrice       Float
  depositPaid       Float         @default(0)
  status           String         @default("PENDING") // PENDING, CONFIRMED, CANCELLED
  notes            String?
  options          String         // Stored as JSON string or comma separated for simplicity
  transferAirport  String?        // For transfer reservations: ASR | NAV
  transferDirection    String?    // arrival | departure | roundtrip
  transferFlightArrival   String?
  transferFlightDeparture String?
  transferHotelName  String?
  startTime         String?        // "HH:MM" selected by guest (tour.startTimes)
  adultCount        Int?
  childCount        Int?          // 4-7 yaş çocuk sayısı
  infantCount       Int?          // 0-3 yaş bebek sayısı
  // Misafir iptal talebi (operasyon onayına kadar bekler)
  cancellationRequestedAt   DateTime?
  cancellationRequestReason  String?
  cancelReason       String?       // free_cancel | customer_request | wrong_reservation | other
  cancelNote         String?
  cancelledBy        String?       // admin | customer
  // Misafir değişiklik talebi (tarih/kişi/not; operasyon onayına kadar bekler)
  updateRequestedAt  DateTime?
  pendingDate        DateTime?
  pendingPax         Int?
  pendingNotes      String?
  couponId         String?       // Kullanılan kupon (varsa)
  couponCode       String?       // Kupon kodu (görüntüleme için)
  originalPrice    Float?        // İndirim öncesi tutar
  discountAmount   Float?        @default(0)  // Uygulanan indirim
  // totalPrice = final price (indirim sonrası)
  cariRecords       CariRecord[]
  promotionId       String?
  promotion         Promotion?    @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  review            Review?
  /** Misafir checkout: cash | transfer | card */
  paymentMethod    String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
}

model Coupon {
  id          String    @id @default(uuid())
  code        String    @unique
  // İndirim (tek tip: percentage veya fixed)
  discountType   String   @default("percentage") // "percentage" | "fixed"
  discountValue  Float    @default(0)
  discountCurrency String? // EUR, TRY - sadece fixed için
  // Eski alanlar (migration uyumluluğu, kademeli kaldırılacak)
  discountPct Float?
  discountAbs Float?
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  validUntil  DateTime?
  // Yeni: iki tarih aralığı
  bookingStart   DateTime  // Rezervasyon dönemi başlangıcı
  bookingEnd     DateTime  // Rezervasyon dönemi bitişi
  activityStart  DateTime  // Aktivite dönemi başlangıcı
  activityEnd    DateTime  // Aktivite dönemi bitişi
  // Kullanım limiti
  usageLimit   Int       @default(0) // 0 = sınırsız
  usageCount   Int       @default(0)
  // Kapsam
  applicableCategories String? // JSON: ["daily-tours","transfer"] veya null = tümü
  minCartAmount Float?
  // Meta
  isActive     Boolean   @default(true)
  internalNote String?
  createdBy    String?
  usages       CouponUsage[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model CouponUsage {
  id              String   @id @default(uuid())
  couponId        String
  coupon          Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  reservationId   String?
  guestName       String
  guestEmail      String?
  usedAt          DateTime @default(now())
  tourName        String
  tourDate        DateTime
  originalAmount  Float
  discountAmount  Float
  finalAmount     Float
  currency        String   @default("EUR")
  createdAt       DateTime @default(now())
}

model CariRecord {
  id                    String    @id @default(uuid())
  reservationId         String?   @unique
  reservation           Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  guestName             String
  hotelName             String?
  roomNumber            String?
  activityType          String    // Balon, Özel Tur, Transfer vb.
  quantity              Int       @default(1)
  activityDate          DateTime
  salePrice             Float
  saleCurrency          String    @default("EUR") // EUR, TRY, USD
  costAmount            Float?
  costCurrency          String?   // EUR, TRY, USD
  costDescription       String?
  agentName             String?   // Dış acenta adı
  paymentMethod         String    @default("cash") // cash, transfer, card
  paymentDestination    String    @default("internal") // internal, agency_direct
  salesperson           String?
  paidToAgency          String?   // paid, pending, unpaid
  reservationConfirmed  Boolean   @default(false)
  confirmationReceived  Boolean   @default(false)
  paymentReceived       Boolean   @default(false)
  profit                Float?    // Hesaplanan: (salePrice*quantity) - (costAmount*quantity)
  notes                 String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model ProductAgeGroup {
  id             String   @id @default(uuid())
  tourId          String
  tour            Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  minAge          Int
  maxAge          Int
  pricingType     String   // free | child | adult | not_allowed
  descriptionEn   String
  descriptionTr   String
  descriptionZh   String?
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model TourImage {
  id         String   @id @default(uuid())
  tourId      String
  tour        Tour     @relation(fields: [tourId], references: [id], onDelete: Cascade)
  url        String
  altEn      String?
  altTr      String?
  altZh      String?
  isPrimary  Boolean  @default(false)
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SiteSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt
}

model Review {
  id                 String       @id @default(uuid())
  tourId             String
  tour               Tour         @relation(fields: [tourId], references: [id], onDelete: Cascade)
  reservationId      String?      @unique
  reservation        Reservation? @relation(fields: [reservationId], references: [id], onDelete: SetNull)
  userId             String?
  user               User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  guestName          String
  guestEmail         String?
  rating             Int
  comment            String
  moderationStatus   String       @default("PENDING") // PENDING | APPROVED | REJECTED
  adminNote          String?
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  @@index([tourId])
  @@index([moderationStatus])
}

model Promotion {
  id                 String        @id @default(uuid())
  name               String
  discountType      String        // percentage | fixed
  discountValue     Float
  discountCurrency  String?
  validFrom         DateTime
  validUntil        DateTime
  bookableFrom      DateTime
  bookableUntil     DateTime
  applicableTourIds Json?
  isActive          Boolean       @default(true)
  reservations      Reservation[]
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
}
