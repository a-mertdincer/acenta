{
  "name": "acenta",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "rm -f tsconfig.tsbuildinfo && tsc --noEmit",
    "quality": "npm run typecheck && npx eslint . && npm run build",
    "prepush": "npm run quality",
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "seed": "prisma db seed",
    "db:up": "docker-compose up -d",
    "db:down": "docker-compose down",
    "db:migrate": "prisma migrate deploy",
    "setup": "prisma migrate deploy && npm run seed",
    "seed:tour-images": "tsx scripts/seed-tour-images.ts",
    "test:deepl": "tsx scripts/test-deepl.ts",
    "translate:all": "tsx scripts/bulk-translate.ts",
    "translate:dry": "tsx scripts/bulk-translate.ts --dry-run",
    "translate:tours": "tsx scripts/bulk-translate.ts --only=tours",
    "translate:attractions": "tsx scripts/bulk-translate.ts --only=attractions",
    "translate:variants": "tsx scripts/bulk-translate.ts --only=variants",
    "translate:options": "tsx scripts/bulk-translate.ts --only=options",
    "prepare": "husky",
    "postinstall": "prisma generate"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0"
    ]
  },
  "dependencies": {
    "@formatjs/intl-localematcher": "^0.8.1",
    "@prisma/adapter-pg": "^7.4.1",
    "@prisma/client": "^7.5.0",
    "bcryptjs": "^3.0.3",
    "lucide-react": "^1.8.0",
    "negotiator": "^1.0.0",
    "next": "16.1.6",
    "next-auth": "^4.24.13",
    "pg": "^8.18.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "resend": "^6.9.2",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/negotiator": "^0.6.4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.3.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "prisma": "^7.5.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
