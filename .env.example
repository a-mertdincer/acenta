# Copy this file to .env and set your values.
#
# Neon (serverless PostgreSQL):
#   DATABASE_URL: Dashboard → Connection string → "Pooled connection" (günlük uygulama için).
#   DIRECT_URL:   Dashboard → Connection string → "Direct connection" (migrate için gerekli).
#   Pooler kullanırken "prisma migrate" advisory lock timeout verir; DIRECT_URL bunu önler.
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxx.region.aws.neon.tech/neondb?sslmode=require"
